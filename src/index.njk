---
layout: base.njk
permalink: /
---

<!-- Top Controls (theme + section dropdown) -->
<div class="top-controls" id="top-controls">
  <button class="top-btn theme-toggle" id="theme-toggle" aria-label="Toggle between light, dark, sepia, and system themes" title="Theme: system (click to cycle)">
    <span class="theme-icon theme-icon--light">☀</span>
    <span class="theme-icon theme-icon--dark">☾</span>
    <span class="theme-icon theme-icon--sepia">◑</span>
    <span class="theme-icon theme-icon--system">◐</span>
  </button>
  <button class="top-btn nav-toggle" id="nav-toggle" aria-label="Navigate sections" aria-haspopup="menu" aria-controls="nav-dropdown" aria-expanded="false">⋯</button>

  <div class="nav-dropdown" id="nav-dropdown" role="menu" aria-label="Section navigation">
    <a class="nav-dropdown__link" role="menuitem" href="#top" data-section="top">Home</a>
    <a class="nav-dropdown__link" role="menuitem" href="#news" data-section="news">News</a>
    <a class="nav-dropdown__link" role="menuitem" href="#research" data-section="research">Research</a>
    <a class="nav-dropdown__link" role="menuitem" href="#demos" data-section="demos">Demos</a>
    <a class="nav-dropdown__link" role="menuitem" href="#reading" data-section="reading">Reading</a>
    <div class="nav-dropdown__divider"></div>
    <button class="nav-dropdown__hint" id="cmd-k-hint" role="menuitem" aria-label="Search: press Command K (or Control K) to open the search palette">Search… <kbd aria-hidden="true">⌘K</kbd></button>
  </div>
</div>

<!-- Hidden stub so main.js (which queries this ID without null-check) doesn't throw -->
<nav id="section-indicator" hidden aria-hidden="true"></nav>

<!-- Command Palette -->
<div class="cmd-palette-overlay" id="cmd-overlay">
  <div class="cmd-palette" id="cmd-palette">
    <div class="cmd-palette__input-wrap">
      <span class="cmd-palette__icon">🔍</span>
      <input class="cmd-palette__input" id="cmd-input" type="text" placeholder="Search papers, tags, sections…"
        aria-label="Search research papers, tags, and sections" autocomplete="off">
      <span class="cmd-palette__kbd" aria-hidden="true">ESC</span>
    </div>
    <div class="cmd-palette__results" id="cmd-results"></div>
  </div>
</div>

<main class="container">

  <!-- HERO -->
  <section class="hero" id="top">
    <div class="hero__inner">
      <div class="hero__text">
        <h1 class="hero__name">{{ site.name }}</h1>
        <p class="hero__tagline">AI Researcher · Computer Science Ph.D. Candidate, University of Michigan</p>
        <div class="hero__bio">
          <p>👋 Hi, I'm an <strong>AI researcher</strong> and a <strong>Computer Science Ph.D. candidate</strong> at the
            <a href="https://cse.engin.umich.edu/">University of Michigan</a>.
            I design and deploy <strong>interactive AI systems</strong> that help solve specific societal challenges across healthcare, wildlife conservation, road safety, and education. My research focuses on topics around <strong>LLMs</strong>, Reinforcement Learning, Representation Learning, and <strong>human-AI interaction</strong>.
          </p>

          <p>
            Previously, I have worked at Microsoft Research: once as a summer intern working on improving interactivity of LLM agents and then as a Research Fellow for two years working on
            scaling <a href="https://www.microsoft.com/en-us/research/project/hams/">HAMS</a>,
            <a href="https://www.microsoft.com/en-us/research/project/vasudha/">Vasudha</a>, and improving multilingual capabilities of LLMs at
            <a href="https://www.microsoft.com/en-us/research/project/project-vellm/">VeLLM</a>.
          </p>
        </div>

        <div class="hero__links">
          {%- for link in profile.links %}
          <a {% if link.primary %}class="hero__link--primary"{% endif %} {% if link.external or link.href[0] != '#' %}target="_blank" rel="noopener"{% endif %} href="{{ link.href }}"{% if link.aria %} aria-label="{{ link.aria }}" title="{{ link.aria }}"{% endif %}>{% if link.icon %}{{ link.icon }} {% endif %}{{ link.label }}</a>
          {%- endfor %}
        </div>
      </div>

      <div class="hero__photo">
        <img alt="Vaibhav Balloli, AI Researcher and Computer Science Ph.D. candidate at the University of Michigan" src="/tn/images/profile.png" width="220" height="220" decoding="async" fetchpriority="high">
      </div>
    </div>
  </section>

  <!-- NEWS -->
  <section class="section news" id="news">
    <h2 class="section-title">News</h2>
    <ul class="news__list" id="news-list" aria-live="polite" aria-busy="true">
      <li class="news__item news__item--loading">
        <span class="news__loading">
          <span class="news__spinner" aria-hidden="true"></span>
          <span>Loading the latest news…</span>
        </span>
      </li>
    </ul>
    <button class="news__view-all" id="news-view-all" type="button" hidden>View all news</button>
  </section>

  <!-- RESEARCH -->
  <section class="section" id="research">
    <h2 class="section-title">Research</h2>
    <p class="research__intro">
      I work on human-centered AI, designing <strong>interactive AI systems</strong> that collaborate with people,
      surface the right uncertainty, and remain reliable when deployed in high-stakes domains such as healthcare,
      wildlife conservation, road safety, and education. My research sits at the intersection of large language
      models, reinforcement learning, representation learning, and human-computer interaction, spanning:
    </p>
    <ul class="research__areas">
      <li><strong>Interactive AI Agents:</strong> models and systems that allow stakeholders to improve their decision making.</li>
      <li><strong>Reliable evaluations:</strong> curating and benchmarking datasets for trustworthy real-world AI deployment.</li>
      <li><strong>Responsible Deployments:</strong> working closely with stakeholders to responsibly deploy these systems in the real world.</li>
    </ul>
    <p class="research__demos-link">Want to see the research in motion? <a href="#demos">Look here for cool demos →</a></p>

    <!-- Filter -->
    <div id="pill-anchor" class="pill-anchor"></div>
    <div class="filter-pill filter-pill--inline" id="filter-pill" role="search">
      <div class="filter-pill__search-wrap">
        <span class="filter-pill__search-icon" aria-hidden="true">🔍</span>
        <label class="visually-hidden" for="filter-pill-input">Search papers by keyword or topic</label>
        <input class="filter-pill__input" id="filter-pill-input" type="text" placeholder="Search papers by keyword or topic"
          aria-label="Search papers by keyword or topic" autocomplete="off">
        <button class="filter-pill__clear" id="filter-pill-clear" type="button" aria-label="Clear search and reset filters" hidden>✕</button>
      </div>
      <div class="filter-pill__divider"></div>
      <div class="filter-pill__tags" id="research-filters" role="group" aria-label="Filter papers by topic">
        <button class="filter-tag filter-tag--active" data-filter="featured" aria-pressed="true">Featured</button>
        <button class="filter-tag" data-filter="all" aria-pressed="false">All</button>
        <button class="filter-tag" data-filter="llms" aria-pressed="false">LLMs</button>
        <button class="filter-tag" data-filter="evals" aria-pressed="false">Evals</button>
        <button class="filter-tag" data-filter="vision" aria-pressed="false">Vision</button>
        <button class="filter-tag" data-filter="healthcare" aria-pressed="false">Healthcare</button>
        <button class="filter-tag" data-filter="social-impact" aria-pressed="false">Social Impact</button>
      </div>
    </div>

    <div class="paper-list" id="paper-list">
      {%- for paper in collections.papers %}
      <article class="paper{% if paper.data.featured %} paper--featured{% endif %}" data-tags="{% if paper.data.featured %}featured,{% endif %}{{ paper.data.topics | join(',') }}" itemscope itemtype="https://schema.org/ScholarlyArticle">
        {%- if paper.data.venues and paper.data.venues.length %}<meta itemprop="datePublished" content="{{ paper.data.venues[0].year }}">{% endif %}
        <div class="paper__meta">
          {%- for v in paper.data.venues %}
          <div class="paper__venue">
            <span class="paper__venue-acronym">{{ v.acronym }}</span>
            <span class="paper__year">{{ v.year }}</span>
            {%- if v.kind %}<span class="paper__venue-kind">{{ v.kind }}</span>{% endif %}
          </div>
          {%- endfor %}
          {%- if paper.data.badges and paper.data.badges.length %}
          <div class="paper__badges">
            {%- for b in paper.data.badges %}
            <span class="paper__badge paper__badge--{{ b.type }}">{{ b.label }}</span>
            {%- endfor %}
          </div>
          {%- endif %}
        </div>
        <div class="paper__body">
          {%- if paper.data.thumb %}
          <div class="paper__thumb">
            <img alt="Thumbnail for {{ paper.data.title }}" src="{{ paper.data.thumb }}" loading="lazy" decoding="async" itemprop="image">
          </div>
          {%- endif %}
          <div class="paper__text">
            <h3 class="paper__title" itemprop="name headline">{{ paper.data.title }}</h3>
            <p class="paper__authors">{% for a in paper.data.authors %}<span itemprop="author" itemscope itemtype="https://schema.org/Person">{% if a.me %}<strong itemprop="name">{{ a.name }}</strong>{% else %}<span itemprop="name">{{ a.name }}</span>{% endif %}</span>{% if not loop.last %}, {% endif %}{% endfor %}</p>
            <div class="paper__desc" itemprop="abstract">{{ paper.templateContent | safe }}</div>
            <div class="paper__actions">
              {%- for l in paper.data.links %}
              <a href="{{ l.href }}" target="_blank" rel="noopener" title="{{ l.label }}: {{ paper.data.title }}"{% if loop.first %} itemprop="url"{% endif %}>{{ l.label }}</a>
              {%- endfor %}
              <button type="button" data-copy-bibtex title="Copy the BibTeX citation for this paper">Copy BibTeX</button>
            </div>
            <pre class="paper__bibtex" hidden>{{ paper.data.bibtex | trim }}</pre>
          </div>
        </div>
      </article>
      {%- endfor %}
    </div>
  </section>

  <!-- COOL DEMOS -->
  <section class="section demos" id="demos">
    <h2 class="section-title">Cool Demos</h2>
    <p class="demos__intro">
      Interactive animations and visualizations from my research projects.
    </p>
    <div class="demos__carousel" id="demos-carousel">
      <button class="demos__nav demos__nav--prev" id="demos-prev" type="button" aria-label="Previous demo" aria-controls="demos-track">‹</button>
      <div class="demos__track" id="demos-track" tabindex="0" aria-label="Research demos, scroll horizontally">
        <figure class="demo-card">
          <div class="demo-card__lottie" data-lottie-src="/lottie/seek-cbm.json" style="--demo-aspect: 1280 / 600" role="img"
            aria-label="Animated demo of SEEK-CBM: editable and interpretable retrieval for elephant re-identification">
          </div>
          <figcaption class="demo-card__caption">
            <h3 class="demo-card__title">SEEK-CBM</h3>
            <p>Editable and interpretable retrieval for elephant re-identification.</p>
            <a href="https://drive.google.com/file/d/1JuWRW6SlzewdU0gJTEZdoZT7_-kp_Ntl/view" target="_blank" rel="noopener">Read the paper →</a>
          </figcaption>
        </figure>
        <figure class="demo-card">
          <div class="demo-card__lottie" data-lottie-src="/lottie/pathfinder.json" style="--demo-aspect: 1000 / 750" role="img"
            aria-label="Animated demo of PATHFinder: interactive agents for tailored prenatal care">
          </div>
          <figcaption class="demo-card__caption">
            <h3 class="demo-card__title">PATHFinder</h3>
            <p>Interactive agents for tailored prenatal care.</p>
            <a href="https://realize-lab.github.io/PATHFinder" target="_blank" rel="noopener">View the project →</a>
          </figcaption>
        </figure>
      </div>
      <button class="demos__nav demos__nav--next" id="demos-next" type="button" aria-label="Next demo" aria-controls="demos-track">›</button>
    </div>
    <div class="demos__hint" id="demos-hint" aria-hidden="true">
      <span class="demos__hint-text">explore more!</span>
      <svg class="demos__hint-arrow" viewBox="0 0 46 64" fill="none" stroke="currentColor" stroke-width="2.6"
        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 58 C 1 41 13 39 17 34 C 24 27 18 19 27 11" />
        <path d="M18 13 L 28 8 L 32 19" />
      </svg>
    </div>
  </section>

  <!-- READING: favorite books & videos -->
  <section class="section library" id="reading">
    <h2 class="section-title">Things I keep going back to</h2>
    <p class="library__intro">
      A short, evolving shelf of books and talks I find myself returning to.
    </p>
    <div class="library__groups">
      <div class="library__group">
        <h3 class="library__group-title">📚 Reading</h3>
        <ul class="library__list">
          {%- for b in library.books %}
          <li class="library__item">
            <div class="library__item-title">
              {%- if b.href %}<a href="{{ b.href }}" target="_blank" rel="noopener">{{ b.title }}</a>{% else %}{{ b.title }}{% endif %}
            </div>
            {%- if b.author %}<div class="library__item-meta">{{ b.author }}</div>{% endif %}
            {%- if b.note %}<div class="library__item-note">{{ b.note }}</div>{% endif %}
          </li>
          {%- endfor %}
        </ul>
      </div>
      <div class="library__group">
        <h3 class="library__group-title">🎬 Talks &amp; videos</h3>
        <ul class="library__list">
          {%- for v in library.videos %}
          <li class="library__item">
            <div class="library__item-title">
              {%- if v.href %}<a href="{{ v.href }}" target="_blank" rel="noopener">{{ v.title }}</a>{% else %}{{ v.title }}{% endif %}
            </div>
            {%- if v.author %}<div class="library__item-meta">{{ v.author }}</div>{% endif %}
            {%- if v.note %}<div class="library__item-note">{{ v.note }}</div>{% endif %}
          </li>
          {%- endfor %}
        </ul>
      </div>
    </div>
  </section>

</main>

